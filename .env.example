# CocoIndex state store (matches docker-compose defaults)
COCOINDEX_DATABASE_URL=postgresql://cocoindex:cocoindex@localhost:55432/cocoindex
COCOINDEX_SOURCE_MAX_INFLIGHT_ROWS=16

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Embedding model (must match between indexer and MCP server)
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIM=4096

# Qdrant endpoints (local Docker defaults)
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=http://localhost:6334
